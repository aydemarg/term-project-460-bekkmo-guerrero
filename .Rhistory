#Load data
data(ames)
# split the data into testing and training sets
set.seed(999)
ames_split = ames |>
initial_split(prop = 0.8)
ames_train = ames_split |>
training()
ames_test <- ames_split |>
testing()
#a. Simple regrssion
model1 = lm(Sale_Price ~ Year_Built + Gr_Liv_Area, data = ames_train)
summary(model1)
#b. Fitted values added to training data
ames_train_aug = augment(model1, data = ames_train)
#c.Calculate RMSE in training data
rmse_model1 = ames_train_aug  |>
summarise(RMSE = sqrt(mean((Sale_Price - .fitted)^2)))
rmse_model1
#d. Compare to the sample mean (baseline)
mean_price = mean(ames_train$Sale_Price)
mean_price
View(ames_train)
# adding categorical variables
model2 = lm(Sale_Price ~ Year_Built + Gr_Liv_Area +
MS_SubClass + MS_Zoning + Neighborhood + Overall_Cond,
data = ames_train)
# Add fitted values
ames_train_aug2 = augment(model2, data = ames_train)
# RMSE
rmse_model2 = ames_train_aug2 |>
summarise(RMSE = sqrt(mean((Sale_Price - .fitted)^2)))
rmse_model2
