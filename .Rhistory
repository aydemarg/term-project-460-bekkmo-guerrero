library(tidyverse)
library(tidymodels)
library(ISLR)
library(glmnet)
# load data
data(Credit)
set.seed(123)
credit_split <-Credit |>
initial_split(prop = 0.8)
credit_train <- credit_split |>
training()
credit_test <- credit_split |>
testing()
# define a recipe to process data
credit_recipe <- recipe(Rating ~ ., data = credit_train) |>
# define ID variable so we don't use it as a predictor
update_role(ID, new_role = "id") |>
# create indicators (dummy vars.) for each categorical or character variable
step_dummy(all_nominal_predictors())
# define a more complex recipe
credit_recipe <- recipe(Rating ~ ., data = credit_train) |>
# define ID variable so we don't use it as a predictor
update_role(ID, new_role = "id") |>
# create polynomial terms for numeric predictors
step_poly(all_numeric_predictors(), degree = 2) |>
# create all possible interactions between continuous and categorical variables
step_interact(~all_numeric_predictors():all_nominal_predictors()) |>
# create indicators (dummy vars.) for each categorical or character variable
step_dummy(all_nominal_predictors()) |>
# remove predictors with ~0 variance
step_nzv(all_predictors())
# Process the data
credit_clean <- credit_recipe |>
prep() |>
juice()
# Define a model
model_lm <- linear_reg() |>
set_engine("lm")
# set up cross-validation
credit_cv <- credit_train |>
vfold_cv(v = 5)
# define a workflow (put it all together)
fit_lm_cv <- workflow() |>
add_model(model_lm) |>
add_recipe(credit_recipe) |>
fit_resamples(credit_cv)
# Extract performance metrics
fit_lm_cv |>
collect_metrics()
# note: mixture is alpha in elasticnet, 1 = lasso, 0 = ridge
reg_model <- linear_reg(
penalty = tune(), mixture = 1
) |>
set_engine("glmnet")
reg_workflow <- workflow() |>
add_model(reg_model) |>
add_recipe(credit_recipe)
# Tune the lambda penalty parameter (estimate using cv for many values)
reg_cv <- reg_workflow |>
tune_grid(credit_cv)
reg_cv |>
show_best()
autoplot(reg_cv, metric = "rmse")
lambdas <- 10^seq(5, -2, length = 1e3)
reg_cv <- reg_workflow |>
tune_grid(
credit_cv,
grid = data.frame(penalty = lambdas),
metrics = metric_set(rmse)
)
reg_cv |>
show_best(metric = "rmse")
autoplot(reg_cv, metric = "rmse")
reg_final <- reg_workflow |>
finalize_workflow(select_best(reg_cv))
# fit model in full training data (all 5 folds)
# and then make predictions in the test set
reg_fit <- reg_final |>
last_fit(credit_split)
reg_fit |>
collect_metrics()
# look at coefficients from the best model
coefs <- reg_fit |>
extract_fit_parsnip() |>
tidy() |>
View()
# make predicitons
test_predictions <- reg_fit |>
augment()
# plot predictions agaisnt true values
ggplot(test_predictions, aes( x = .pred, y = Rating)) +
geom_point(color = "blue") +
geom_abline()
# what to change for elasticnet
reg_model <- linear_reg(penalty = tune(), mixture = tune()) |>
set_engine("glmnet")
reg_cv <- reg_workflow |>
tune_grid(
credit_cv,
grid <- grid_regular(mixture(), penalty(), levels = 10:10),
metric = metric_set(rmse)
)
